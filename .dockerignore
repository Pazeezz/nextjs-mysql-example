# Dependencies — reinstalled inside the image
node_modules/

# Next.js build output — rebuilt inside the image
.next/
out/

# Environment secrets — never bake into the image
.env
.env.local
.env*.local

# Git metadata
.git/
.gitignore

# CI/CD and config files not needed at runtime
.github/
nginx/

# Documentation
README.md
debug-report.md
*.md

# OS / IDE noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local Docker volumes
mysql_data/

# Logs
npm-debug.log*
yarn-debug.log*
